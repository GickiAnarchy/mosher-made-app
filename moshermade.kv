###
###	CONTROLLER
###

<RootController>:
	screen_manager:screen_manager
    toolbar:toolbar
    nav_drawer: nav_drawer
    orientation: "vertical"

	MDTopAppBar:
		id: toolbar
		size_hint_y: None
		height: dp(50)
		MDTopAppBarLeadingButtonContainer:
			MDActionTopAppBarButton:
				icon:"menu"
				on_release: nav_drawer.set_state("open")
		MDTopAppBarTitle:
			id:toolbar_title
			text:"Home"
			pos_hint:{"center_x":0.5}
			halign:"center"
	
	MDNavigationLayout:
                
		RootScreenManager:
			id:screen_manager
		
		MDNavigationDrawer:
			id: nav_drawer
			type:"selected"

			MDBoxLayout: # Use a BoxLayout to control vertical positioning
				orientation: "vertical"

				MDNavigationDrawerMenu: # This will contain all regular menu items
					adaptive_height: True # Important so it doesn't take all vertical space

					MDNavigationDrawerLabel:
						text: "Navigation"
					
					MDNavigationDrawerItem:
						on_release: root.goto("home")
						MDNavigationDrawerItemLeadingIcon:
							icon: "home"
						MDNavigationDrawerItemText:
							text: "Home"

					MDNavigationDrawerItem:
						on_release: root.goto("add")
						MDNavigationDrawerItemLeadingIcon:
							icon: "add"
						MDNavigationDrawerItemText:
							text: "Add Employer/Client"

				Widget: # This spacer will push the next item to the very bottom

				MDNavigationDrawerItem: # This is the app.stop() item, now at the bottom
					size_hint_y: None
					height: dp(40) # Fixed height
					on_release: root.close_me()
					MDNavigationDrawerItemLeadingIcon:
						icon: "close"



###
###	SCREENS
###


<HomeScreen>:
	clocked_in_box:clocked_in_box
	
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
		md_bg_color: 1,1,1,1
            
        Widget:

		MDBoxLayout:
			orientation:"vertical"
			ScrollView:
				MDBoxLayout:
					id:clocked_in_box
					orientation:"vertical"
					size_hint_y:None
					height: self.minimum_height
					spacing: dp(20)


<LoadingScreen>:
    logo:logo
    name:"loading"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDBoxLayout:
            orientation:"vertical"
            size_hint: 1, 1
            pos_hint:{"center_x":0.5,"center_y":0.5}
            spacing:dp(1)
            
            SpinningLogo:
                id:logo
                source:"assets/icon.png"
                pos_hint: {"center_x": 0.5}
           
            MDLabel:
                text: "Loading..."
                valign:"top"
                halign:"center"


<AddScreen>:
    name: "add"
    
    MDBoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "20dp"

        MDLabel:
            text: "Management Center"
            style: "HeadlineMedium"
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]

        # --- ADD EMPLOYEE SECTION ---
        MDCard:
            orientation: "vertical"
            padding: "12dp"
            spacing: "10dp"
            style: "elevated"
            adaptive_height: True

            MDLabel:
                text: "Add New Employee"
                style: "TitleMedium"

            MDTextField:
                id: emp_name_field
                mode: "outlined"
                hint_text: "Employee Name"
                
            MDTextField:
                id: emp_wage_field
                mode: "outlined"
                hint_text: "Hourly Wage (e.g. 20.00)"
                input_filter: "float"

            MDButton:
                style: "filled"
                pos_hint: {"center_x": .5}
                on_release: root.save_employee()
                MDButtonText:
                    text: "Register Employee"

        # --- ADD EMPLOYER SECTION ---
        MDCard:
            orientation: "vertical"
            padding: "12dp"
            spacing: "10dp"
            style: "elevated"
            adaptive_height: True

            MDLabel:
                text: "Add New Employer / Job Site"
                style: "TitleMedium"

            MDTextField:
                id: employer_name_field
                mode: "outlined"
                hint_text: "Employer/Company Name"
                
            MDTextField:
                id: employer_loc_field
                mode: "outlined"
                hint_text: "Location / Address (Optional)"

            MDButton:
                style: "filled"
                pos_hint: {"center_x": .5}
                on_release: root.save_employer()
                MDButtonText:
                    text: "Register Employer"




###
###	COMPONENTS
###


<CheckItem>:
    checkbox: checkbox
    orientation: "horizontal"
    size_hint_y: None
    height: dp(48)  # Fixed height is much faster than adaptive_height
    padding: dp(4)
    spacing: dp(8)

    MDCheckbox:
        id: checkbox
        group: root.group
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {"center_y": .5}
    
    MDLabel:
        text: root.name_text
        halign: "left"
        valign: "center"
        shorten: True
        shorten_from: "right"


<ButtonLabel>:
	btn: btn
	lbl: lbl

	orientation: "horizontal"
	padding: 10
	spacing: 10

	MDButton:
		id: btn
		size_hint_x: 0.3
		on_release: root.on_release(root.btn)

 
<SpinningLogo>:
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix