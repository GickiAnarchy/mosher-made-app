



##    CONTROLLER

<RootController>:
    topbar:topbar
    nav_drawer:nav_drawer
    screen_manager:screen_manager
    
    MDTopAppBar:
        id:topbar
        pos_hint:{"top":1}
        type: "small"  # Options: "small", "center", "medium", "large"

        MDTopAppBarLeadingButtonContainer:

            MDActionTopAppBarButton:
                icon:"menu"
                on_release: nav_drawer.set_state("toggle")

        MDBoxLayout:
            orientation: "vertical"
            adaptive_size: True
            pos_hint: {"center_x": .5, "center_y": .5}

            FitImage:
                source: "assets/title.png"
                size_hint: None, None
                
                # size: dp(120), dp(40) # Adjust to your logo's aspect ratio

            # FitImage:
            #     source:"assets/title.png"
            #     pos_hint:{"center_x":0.5}
            #     size_hint: (1,None)
            #     height: dp(80)
            #     #height: self.width * 0.5625
            #     fit_mode:"contain"
            #     radius: [dp(16), dp(16), 0, 0] # Optional M3 rounded corners

            # MDTopAppBarTitle:
            #     id: topbar_title
            #     text: "Home"
            #     pos_hint: {"center_x": .5}

    MDNavigationLayout:
        
        MDScreenManager:
            id:screen_manager

        MDNavigationDrawer:
            id:nav_drawer
            radius:0,dp(16),dp(16),0

            MDNavigationDrawerMenu:
                
                MDNavigationDrawerHeader:
                    padding: "16dp", 0, "16dp", "16dp"
                    MDLabel:
                        text: "Menu"
                        adaptive_height: True
                        font_style: "Title"
                        role: "large"

                MDNavigationDrawerItem:
                    on_release: root.goto("home")
                    
                    MDNavigationDrawerItemLeadingIcon:
                        icon: "home"
                    
                    MDNavigationDrawerItemText:
                        text: "Home"

                MDNavigationDrawerItem:
                    on_release: root.goto("create")
                    
                    MDNavigationDrawerItemLeadingIcon:
                        icon:"plus-box"
                    
                    MDNavigationDrawerItemText:
                        text: "Create"


##    SCREENS

<HomeScreen>:
    name:"home"

    MDBoxLayout:
        orientation:"vertical"
        padding:10
        spacing:10
        
        MDLabel:
            text:"'No one mows a lawn like Mosher mows a lawn'"
            halign:"center"
        
        Widget:
            size_hint_y:0.9 


<CreateScreen>:
    name:"create"

    MDBoxLayout:
        orientation:"vertical"
        padding:10
        spacing:10



##    POPUPS
<CreateDialog>:
    message:message
    create_type:create_type
    create_field:create_field
    
    size_hint:(0.8, 0.4)
    opacity:0
    title:"Create"
    
    MDBoxLayout:
        orientation:"vertical"
        padding:10
        spacing:10

        MDLabel:
            id:message
            halign:"center"
            valign:"top"
            
        MDBoxLayout:
            orientation:"vertical"
            padding:10
            spacing:10

            MDLabel:
                text:create_type
                size_hint_x:0.2
                halign:"right"
                
            MDTextField:
                id:create_field
                size_hint_x:0.8