<RootController>:
	screen_manager:screen_manager
    toolbar:toolbar
    nav_drawer: nav_drawer
    orientation: "vertical"

	MDTopAppBar:
		id: toolbar
		size_hint_y: None
		height: dp(50)
		MDTopAppBarLeadingButtonContainer:
			MDActionTopAppBarButton:
				icon:"menu"
				on_release: nav_drawer.set_state("open")
		MDTopAppBarTitle:
			text:"Home"
			pos_hint:{"center_x":0.5}
			halign:"center"
	
	MDNavigationLayout:
                
		MDScreenManager:
			id:screen_manager
		
		MDNavigationDrawer:
			id: nav_drawer
			type:"selected"

			MDNavigationDrawerMenu:

				MDNavigationDrawerLabel:
					text: "Navigation"
				
				MDNavigationDrawerItem:
					on_release: root.goto("home")
					MDNavigationDrawerItemLeadingIcon:
						icon: "home"
					MDNavigationDrawerItemText:
						text: "Home"

				MDNavigationDrawerItem:
				    on_release: root.goto("clock")
					MDNavigationDrawerItemLeadingIcon:
						icon: "clock"
					MDNavigationDrawerItemText:
						text: "Clock"


<HomeScreen>:
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
        
        FitImage:
            source:"assets/mm_title.png"
            size_hint: (None, None)
			width: self.texture_size[0]
            pos_hint: {"center_x":0.5}
            height: dp(100)
            
        Widget:

		MDBoxLayout:
			orientation:"vertical"
			ScrollView:
				MDBoxLayout:
					id:on_clock_box
					orientation:"vertical"
					size_hint_y:None
					height: self.minimum_height
					spacing: dp(20)					


<TimeClockScreen>:
	employers_cbs:employers_cbs
	check_items_container: check_items_container
	name:"clock"
	
	MDBoxLayout:
		orientation:"vertical"
		padding: 15

		MDBoxLayout:
			orientation:"vertical"
			padding: 10
			spacing: 10
			#pos_hint: {"center_x":0.5, "top": 0.1}
			
			canvas.before:
			    Color:
			        rgba: 0.1, 1, 0.3, 0.6
			    Line:
                    width: 5
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 25)

			MDLabel:
				text:"Clock In/Out"
				size_hint: (0.9, None)
				halign: "center"
				#pos_hint: {"center_x":0.5}
				height: dp(50)
			
			ScrollView:
				size_hint_y: 0.4
				MDGridLayout:
					id: check_items_container
					cols: 3
					adaptive_height: True
					padding: dp(10)
					spacing: dp(10)
		
		MDBoxLayout:
			orientation:"vertical"
			padding: 10
			spacing: 10
			#pos_hint: {"center_x":0.5, "top": 0.1}
			
			canvas.before:
			    Color:
			        rgba: 0.1, 1, 0.3, 0.6
			    Line:
                    width: 5
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 25)

			MDLabel:
				text:"Which Employer?"
				size_hint: (0.9, None)
				halign: "center"
				#pos_hint: {"center_x":0.5}
				height: dp(50)
			
			ScrollView:
				size_hint_y: 0.4
				MDGridLayout:
					id: employers_cbs
					cols: 3
					adaptive_height: True
					padding: dp(10)
					spacing: dp(10)

		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10
			pos_hint: {"center_x":0.5, "top": 0.8}

			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.handle_clock_in()
				MDButtonText:
					text: "Clock In"
			
			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.handle_clock_out()
				MDButtonText:
					text: "Clock Out"


<LoadingScreen>:
    logo:logo
    name:"loading"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDBoxLayout:
            orientation:"vertical"
            size_hint: 0.8, 0.6
            pos_hint:{"center_x":0.5,"center_y":0.5}
            
            SpinningLogo:
                id:logo
                source:"assets/icon.png"
                pos_hint: {"center_x": 0.5}
            
            MDLabel:
                text: "Loading..."
                valign:"top"
                halign:"center"



###
###	COMPONENTS
###


<CheckItem>:
	checkbox: checkbox
	adaptive_height: True
	
	MDCheckbox:
		id: checkbox
		group: root.group
	
	MDLabel:
		text: root.name_text
		adaptive_height: True
		padding_x: "12dp"
		pos_hint: {"center_y": 0.5}


<ButtonLabel>:
	btn: btn
	lbl: lbl

	orientation: "horizontal"
	padding: 10
	spacing: 10

	MDButton:
		id: btn
		size_hint_x: 0.3
		on_release: root.on_release(root.btn)


<SpinningLogo>:
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix