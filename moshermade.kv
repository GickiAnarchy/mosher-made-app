<RootController>:
	screen_manager:screen_manager
    toolbar:toolbar
    nav_drawer: nav_drawer
    orientation: "vertical"

	MDTopAppBar:
		id: toolbar
		size_hint_y: None
		height: dp(50)
		MDTopAppBarLeadingButtonContainer:
			MDActionTopAppBarButton:
				icon:"menu"
				on_release: nav_drawer.set_state("open")
		MDTopAppBarTitle:
			text:"Home"
			pos_hint:{"center_x":0.5}
			halign:"center"
	
	MDNavigationLayout:
		
		#gationLayout:

#		
#		canvas.before:
#    		Color:
#                rgba: 0.2, 0.5, 0.2, 1
#            RoundedRectangle:
#                pos: self.pos
#     
                
		MDScreenManager:
			id:screen_manager
		
		MDNavigationDrawer:
			id: nav_drawer

			MDNavigationDrawerMenu:

				MDNavigationDrawerLabel:
					text: "Navigation"
				
				MDNavigationDrawerItem:
					on_release: root.goto("home")
					MDNavigationDrawerItemLeadingIcon:
						icon: "home"
					MDNavigationDrawerItemText:	
						text: "Home"
				
				MDNavigationDrawerItem:
					on_release: root.goto("clock")
					MDNavigationDrawerItemLeadingIcon:
						icon: "clock"
					MDNavigationDrawerItemText:	
						text: "Time Clock"
				
				MDNavigationDrawerItem:
					on_release: root.goto("inout")
					MDNavigationDrawerItemLeadingIcon:
						icon: "briefcase-clock"
					MDNavigationDrawerItemText:	
						text: "In Out"
					
				

<HomeScreen>:
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
        
        FitImage:
            source:"assets/mm_title.png"
            size_hint: (None, None)
			width: self.texture_size[0]
            pos_hint: {"center_x":0.5}
            height: dp(100)
            
        Widget:

		MDBoxLayout:
			orientation:"vertical"
			ScrollView:
				MDBoxLayout:
					id:on_clock_box
					orientation:"vertical"
					size_hint_y:None
					height: self.minimum_height
					spacing: dp(20)					


<InOutScreen>:
	name:"inout"
	
	MDBoxLayout:
		orientation:"vertical"
		padding: 15

		MDBoxLayout:
			orientation:"vertical"
			padding: 10
			spacing: 10
			pos_hint: {"center_x":0.5, "top": 0.1}
		
			MDLabel:
				text:"Clock In/Out"
				size_hint: (0.9, None)
				halign: "center"
				pos_hint: {"center_x":0.5}
				height: dp(50)
			
			ScrollView:
				size_hint_y: 0.4
				MDGridLayout:
					id: check_items_container
					cols: 3
					adaptive_height: True
					padding: dp(10)
					spacing: dp(10)
			
		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10
			pos_hint: {"center_x":0.5, "top": 0.8}

			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.clock_in()
				MDButtonText:
					text: "Clock In"
			
			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.clock_out()
				MDButtonText:
					text: "Clock Out"


<LogWorkScreen>:
	name:"logwork"
	
	MDBoxLayout:
		orientation:"vertical"
		
		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10

			MDLabel:
				id:employee_label
				text:"Employee:"
				size_hint: 0.4, None
				height: dp(45)

			MDButton:
				id: employee_button
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.6
				on_release: root.open_employee_menu(self)
				MDButtonText:
					text: "Employees"

		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10

			MDLabel:
				id:employer_label
				text:"Employer:"
				size_hint: 0.4, None
				height: dp(45)

			MDButton:
				id: employer_button
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.6
				on_release: root.open_employer_menu(self)
				MDButtonText:
					text: "Employers"


<LoadingScreen>:
    logo:logo
    name:"loading"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDBoxLayout:
            orientation:"vertical"
            size_hint: 0.6, 0.5
            
            SpinningLogo:
                id:logo
                source:"assets/icon.png"
                pos_hint: {"center_x": 0.5}
            
            MDLabel:
                text: "Loading..."
                halign:"center"



###
###	COMPONENTS
###


<CheckItem>:
	checkbox: checkbox
	adaptive_height: True
	
	MDCheckbox:
		id: checkbox
		group: root.group
	
	MDLabel:
		text: root.name_text
		adaptive_height: True
		padding_x: "12dp"
		pos_hint: {"center_y": 0.5}


<ButtonLabel>:
	btn: btn
	lbl: lbl

	orientation: "horizontal"
	padding: 10
	spacing: 10

	MDButton:
		id: btn
		size_hint_x: 0.3
		on_release: root.on_release(root.btn)