<RootController>:
	screen_manager:screen_manager
    toolbar:toolbar
    nav_drawer: nav_drawer
    orientation: "vertical"

	MDTopAppBar:
		id: toolbar
		size_hint_y: None
		height: dp(50)
		MDTopAppBarLeadingButtonContainer:
			MDActionTopAppBarButton:
				icon:"menu"
				on_release: nav_drawer.set_state("open")
		MDTopAppBarTitle:
			id:toolbar_title
			text:"Home"
			pos_hint:{"center_x":0.5}
			halign:"center"
	
	MDNavigationLayout:
                
		RootScreenManager:
			id:screen_manager
		
		MDNavigationDrawer:
			id: nav_drawer
			type:"selected"

			MDBoxLayout: # Use a BoxLayout to control vertical positioning
				orientation: "vertical"

				MDNavigationDrawerMenu: # This will contain all regular menu items
					adaptive_height: True # Important so it doesn't take all vertical space

					MDNavigationDrawerLabel:
						text: "Navigation"
					
					MDNavigationDrawerItem:
						on_release: root.goto("home")
						MDNavigationDrawerItemLeadingIcon:
							icon: "home"
						MDNavigationDrawerItemText:
							text: "Home"

					MDNavigationDrawerItem:
						on_release: root.goto("clock")
						MDNavigationDrawerItemLeadingIcon:
							icon: "clock"
						MDNavigationDrawerItemText:
							text: "Clock"
					
					MDNavigationDrawerItem:
						on_release: root.goto("add")
						MDNavigationDrawerItemLeadingIcon:
							icon: "add"
						MDNavigationDrawerItemText:
							text: "Add Employer/Client"

				Widget: # This spacer will push the next item to the very bottom

				MDNavigationDrawerItem: # This is the app.stop() item, now at the bottom
					size_hint_y: None
					height: dp(40) # Fixed height
					on_release: root.close_me()
					MDNavigationDrawerItemLeadingIcon:
						icon: "close"


<HomeScreen>:
	clocked_in_box:clocked_in_box
	
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
		md_bg_color: 0,1,1,1
            
        Widget:

		MDBoxLayout:
			orientation:"vertical"
			ScrollView:
				MDBoxLayout:
					id:clocked_in_box
					orientation:"vertical"
					size_hint_y:None
					height: self.minimum_height
					spacing: dp(20)					


<TimeClockScreen>:
    employers_cbs: employers_cbs
    check_items_container: check_items_container
    name: "clock"
    
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(10)

        # Section 1: Employees
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: 0.45 # Give it a specific portion of the screen
            canvas.before:
                Color:
                    rgba: 0.1, 1, 0.3, 0.2 # Toned down the alpha for performance
                Line:
                    width: dp(2)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

            MDLabel:
                text: "Clock In/Out"
                size_hint_y: None
                height: dp(40)
                halign: "center"
            
            ScrollView:
                do_scroll_x: False
                MDGridLayout:
                    id: check_items_container
                    cols: 2 # Reduced to 2 columns for better fit/less overlap
                    adaptive_height: True
                    spacing: dp(5)
                    padding: dp(5)
        
        # Section 2: Employers
        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: 0.45
            canvas.before:
                Color:
                    rgba: 0.1, 1, 0.3, 0.2
                Line:
                    width: dp(2)
                    rounded_rectangle: (self.x, self.y, self.width, self.height, dp(15))

            MDLabel:
                text: "Which Employer?"
                size_hint_y: None
                height: dp(40)
                halign: "center"
            
            ScrollView:
                do_scroll_x: False
                MDGridLayout:
                    id: employers_cbs
                    cols: 2
                    adaptive_height: True
                    spacing: dp(5)
                    padding: dp(5)

        # Section 3: Buttons
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(60)
            spacing: dp(15)
            padding: dp(5)

            MDButton:
                style: "filled"
                size_hint_x: 0.5
                on_release: root.handle_clock_in()
                MDButtonText:
                    text: "Clock In"
            
            MDButton:
                style: "filled"
                size_hint_x: 0.5
                on_release: root.handle_clock_out()
                MDButtonText:
                    text: "Clock Out"


<LoadingScreen>:
    logo:logo
    name:"loading"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDBoxLayout:
            orientation:"vertical"
            size_hint: 1, 1
            pos_hint:{"center_x":0.5,"center_y":0.5}
            spacing:dp(1)
            
            SpinningLogo:
                id:logo
                source:"assets/icon.png"
                pos_hint: {"center_x": 0.5}
           
            MDLabel:
                text: "Loading..."
                valign:"top"
                halign:"center"


<EditTimeScreen>:
	name:"edittime"

	MDBoxLayout:
		orientation:"vertical"
		padding: 15
		spacing: dp(15)
		
		MDBoxLayout:
			orientation:"vertical"
			padding: dp(10)
			spacing: dp(15)
			adaptive_height: True

			# Employee Selection
			MDButton:
				style: "tonal"
				on_release: root.open_employee_menu(self)
				size_hint_x: 1
				MDButtonText:
					text: root.selected_employee

			# Employer Selection
			MDButton:
				style: "tonal"
				on_release: root.open_employer_menu(self)
				size_hint_x: 1
				MDButtonText:
					text: root.selected_employer

			# Date Selection
			MDButton:
				style: "tonal"
				on_release: root.edit_date()
				size_hint_x: 1
				MDButtonText:
					text: f"Date: {root.selected_date}"

			# Time Selection Row
			MDBoxLayout:
				orientation: "horizontal"
				spacing: dp(10)
				size_hint_y: None
				height: self.minimum_height

				MDButton:
					style: "tonal"
					on_release: root.edit_time("in")
					size_hint_x: 0.5
					MDButtonText:
						text: f"In: {root.time_in}"

				MDButton:
					style: "tonal"
					on_release: root.edit_time("out")
					size_hint_x: 0.5
					MDButtonText:
						text: f"Out: {root.time_out}"

			# Notes Field
			MDTextField:
				id: note_field
				mode: "outlined"
				MDTextFieldHintText:
					text: "Notes / Details"

		Widget: # Spacer

		MDButton:
			style: "filled"
			on_release: root.save_shift()
			pos_hint: {"center_x": .5}
			size_hint_x: .8
			MDButtonText:
				text: "Save Shift Log"


<InputKeyScreen>:
    creds_field:creds_field
    
    name:"needkey"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDLabel:
            text:"Enter the Google Service Account Credentials"
            halign:"center"
    
        MDTextField:
            id: creds_field
            multiline: True
            size_hint: 0.8, 0.8
            pos_hint:{"center_x":0.5}
            
        MDButton:
            on_release:root.check_creds()
            size_hint: 0.4, None
            height: dp(40)
            pos_hint:{"center_x":0.5}
            
            MDButtonText:
                text: "Check Credentials"


<AddScreen>:
    name: "add"
    
    MDBoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "20dp"

        MDLabel:
            text: "Management Center"
            style: "HeadlineMedium"
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]

        # --- ADD EMPLOYEE SECTION ---
        MDCard:
            orientation: "vertical"
            padding: "12dp"
            spacing: "10dp"
            style: "elevated"
            adaptive_height: True

            MDLabel:
                text: "Add New Employee"
                style: "TitleMedium"

            MDTextField:
                id: emp_name_field
                mode: "outlined"
                hint_text: "Employee Name"
                
            MDTextField:
                id: emp_wage_field
                mode: "outlined"
                hint_text: "Hourly Wage (e.g. 20.00)"
                input_filter: "float"

            MDButton:
                style: "filled"
                pos_hint: {"center_x": .5}
                on_release: root.save_employee()
                MDButtonText:
                    text: "Register Employee"

        # --- ADD EMPLOYER SECTION ---
        MDCard:
            orientation: "vertical"
            padding: "12dp"
            spacing: "10dp"
            style: "elevated"
            adaptive_height: True

            MDLabel:
                text: "Add New Employer / Job Site"
                style: "TitleMedium"

            MDTextField:
                id: employer_name_field
                mode: "outlined"
                hint_text: "Employer/Company Name"
                
            MDTextField:
                id: employer_loc_field
                mode: "outlined"
                hint_text: "Location / Address (Optional)"

            MDButton:
                style: "filled"
                pos_hint: {"center_x": .5}
                on_release: root.save_employer()
                MDButtonText:
                    text: "Register Employer"




###
###	COMPONENTS
###


<CheckItem>:
    checkbox: checkbox
    orientation: "horizontal"
    size_hint_y: None
    height: dp(48)  # Fixed height is much faster than adaptive_height
    padding: dp(4)
    spacing: dp(8)

    MDCheckbox:
        id: checkbox
        group: root.group
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {"center_y": .5}
    
    MDLabel:
        text: root.name_text
        halign: "left"
        valign: "center"
        # Ensure text stays on one line to prevent height recalculations
        shorten: True
        shorten_from: "right"



<ButtonLabel>:
	btn: btn
	lbl: lbl

	orientation: "horizontal"
	padding: 10
	spacing: 10

	MDButton:
		id: btn
		size_hint_x: 0.3
		on_release: root.on_release(root.btn)

 
<SpinningLogo>:
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix