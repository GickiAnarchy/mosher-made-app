<RootController>:
	screen_manager:screen_manager
    toolbar:toolbar
    nav_drawer: nav_drawer
    orientation: "vertical"

	MDTopAppBar:
		id: toolbar
		size_hint_y: None
		height: dp(50)
		MDTopAppBarLeadingButtonContainer:
			MDActionTopAppBarButton:
				icon:"menu"
				on_release: nav_drawer.set_state("open")
		MDTopAppBarTitle:
			id:toolbar_title
			text:"Home"
			pos_hint:{"center_x":0.5}
			halign:"center"
	
	MDNavigationLayout:
                
		RootScreenManager:
			id:screen_manager
		
		MDNavigationDrawer:
			id: nav_drawer
			type:"selected"

			MDBoxLayout: # Use a BoxLayout to control vertical positioning
				orientation: "vertical"

				MDNavigationDrawerMenu: # This will contain all regular menu items
					adaptive_height: True # Important so it doesn't take all vertical space

					MDNavigationDrawerLabel:
						text: "Navigation"
					
					MDNavigationDrawerItem:
						on_release: root.goto("home")
						MDNavigationDrawerItemLeadingIcon:
							icon: "home"
						MDNavigationDrawerItemText:
							text: "Home"

					MDNavigationDrawerItem:
						on_release: root.goto("clock")
						MDNavigationDrawerItemLeadingIcon:
							icon: "clock"
						MDNavigationDrawerItemText:
							text: "Clock"
					
					MDNavigationDrawerItem:
						on_release: root.goto("edittime")
						MDNavigationDrawerItemLeadingIcon:
							icon: "timer"
						MDNavigationDrawerItemText:
							text: "Add/Edit Time"

				Widget: # This spacer will push the next item to the very bottom

				MDNavigationDrawerItem: # This is the app.stop() item, now at the bottom
					size_hint_y: None
					height: dp(40) # Fixed height
					on_release: root.close_me()
					MDNavigationDrawerItemLeadingIcon:
						icon: "close"


<HomeScreen>:
	clocked_in_box:clocked_in_box
	
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
		md_bg_color: 0,1,1,1
            
        Widget:

		MDBoxLayout:
			orientation:"vertical"
			ScrollView:
				MDBoxLayout:
					id:clocked_in_box
					orientation:"vertical"
					size_hint_y:None
					height: self.minimum_height
					spacing: dp(20)					


<TimeClockScreen>:
	employers_cbs:employers_cbs
	check_items_container: check_items_container
	name:"clock"
	
	MDBoxLayout:
		orientation:"vertical"
		padding: 15

		MDBoxLayout:
			orientation:"vertical"
			padding: 10
			spacing: 10
			#pos_hint: {"center_x":0.5, "top": 0.1}
			
			canvas.before:
			    Color:
			        rgba: 0.1, 1, 0.3, 0.6
			    Line:
                    width: 5
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 25)

			MDLabel:
				text:"Clock In/Out"
				size_hint: (0.9, None)
				halign: "center"
				#pos_hint: {"center_x":0.5}
				height: dp(50)
			
			ScrollView:
				size_hint_y: 0.4
				MDGridLayout:
					id: check_items_container
					cols: 3
					adaptive_height: True
					padding: dp(10)
					spacing: dp(10)
		
		MDBoxLayout:
			orientation:"vertical"
			padding: 10
			spacing: 10
			#pos_hint: {"center_x":0.5, "top": 0.1}
			
			canvas.before:
			    Color:
			        rgba: 0.1, 1, 0.3, 0.6
			    Line:
                    width: 5
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 25)

			MDLabel:
				text:"Which Employer?"
				size_hint: (0.9, None)
				halign: "center"
				#pos_hint: {"center_x":0.5}
				height: dp(50)
			
			ScrollView:
				size_hint_y: 0.4
				MDGridLayout:
					id: employers_cbs
					cols: 3
					adaptive_height: True
					padding: dp(10)
					spacing: dp(10)

		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10
			pos_hint: {"center_x":0.5, "top": 0.8}

			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.handle_clock_in()
				MDButtonText:
					text: "Clock In"
			
			MDButton:
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.5
				on_release: root.handle_clock_out()
				MDButtonText:
					text: "Clock Out"


<LoadingScreen>:
    logo:logo
    name:"loading"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDBoxLayout:
            orientation:"vertical"
            size_hint: 1, 1
            pos_hint:{"center_x":0.5,"center_y":0.5}
            spacing:dp(1)
            
            SpinningLogo:
                id:logo
                source:"assets/icon.png"
                pos_hint: {"center_x": 0.5}
           
            MDLabel:
                text: "Loading..."
                valign:"top"
                halign:"center"


<EditTimeScreen>:
	name:"edittime"

	MDBoxLayout:
		orientation:"vertical"
		padding: 15
		spacing: dp(15)
		
		MDBoxLayout:
			orientation:"vertical"
			padding: dp(10)
			spacing: dp(15)
			adaptive_height: True

			# Employee Selection
			MDButton:
				style: "tonal"
				on_release: root.open_employee_menu(self)
				size_hint_x: 1
				MDButtonText:
					text: root.selected_employee

			# Employer Selection
			MDButton:
				style: "tonal"
				on_release: root.open_employer_menu(self)
				size_hint_x: 1
				MDButtonText:
					text: root.selected_employer

			# Date Selection
			MDButton:
				style: "tonal"
				on_release: root.edit_date()
				size_hint_x: 1
				MDButtonText:
					text: f"Date: {root.selected_date}"

			# Time Selection Row
			MDBoxLayout:
				orientation: "horizontal"
				spacing: dp(10)
				size_hint_y: None
				height: self.minimum_height

				MDButton:
					style: "tonal"
					on_release: root.edit_time("in")
					size_hint_x: 0.5
					MDButtonText:
						text: f"In: {root.time_in}"

				MDButton:
					style: "tonal"
					on_release: root.edit_time("out")
					size_hint_x: 0.5
					MDButtonText:
						text: f"Out: {root.time_out}"

			# Notes Field
			MDTextField:
				id: note_field
				mode: "outlined"
				MDTextFieldHintText:
					text: "Notes / Details"

		Widget: # Spacer

		MDButton:
			style: "filled"
			on_release: root.save_shift()
			pos_hint: {"center_x": .5}
			size_hint_x: .8
			MDButtonText:
				text: "Save Shift Log"


<InputKeyScreen>:
    creds_field:creds_field
    
    name:"needkey"
    
    MDBoxLayout:
        orientation:"vertical"
        
        MDLabel:
            text:"Enter the Google Service Account Credentials"
            halign:"center"
    
        MDTextField:
            id: creds_field
            multiline: True
            size_hint: 0.8, 0.8
            pos_hint:{"center_x":0.5}
            
        MDButton:
            on_release:root.check_creds()
            size_hint: 0.4, None
            height: dp(40)
            pos_hint:{"center_x":0.5}
            
            MDButtonText:
                text: "Check Credentials"



###
###	COMPONENTS
###


<CheckItem>:
	checkbox: checkbox
	adaptive_height: True
	
	MDCheckbox:
		id: checkbox
		group: root.group
	
	MDLabel:
		text: root.name_text
		adaptive_height: True
		padding_x: "12dp"
		pos_hint: {"center_y": 0.5}


<ButtonLabel>:
	btn: btn
	lbl: lbl

	orientation: "horizontal"
	padding: 10
	spacing: 10

	MDButton:
		id: btn
		size_hint_x: 0.3
		on_release: root.on_release(root.btn)

 
<SpinningLogo>:
    canvas.before:
        PushMatrix
        Rotate:
            angle: self.angle
            origin: self.center
    canvas.after:
        PopMatrix