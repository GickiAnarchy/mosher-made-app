



<HomeScreen>:
    name:"home"
    
    MDBoxLayout:
        orientation:"vertical"
        padding: 15
        
        FitImage:
            source:"assets/mm_title.png"
            size_hint: (1, None)
            pos_hint: {"center_x":0.5}
            height: dp(80)
            
        Widget:
            
            





<LogWorkScreen>:
	name:"logwork"
	
	MDBoxLayout:
		orientation:"vertical"
		
		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10

			MDLabel:
				id:employee_label
				text:"Employee:"
				size_hint: 0.4, None
				height: dp(45)

			MDButton:
				id: employee_button
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.6
				on_release: root.open_employee_menu(self)
				MDButtonText:
					text: "Employees"

		MDBoxLayout:
			orientation:"horizontal"
			padding: 10
			spacing: 10

			MDLabel:
				id:employer_label
				text:"Employer:"
				size_hint: 0.4, None
				height: dp(45)

			MDButton:
				id: employer_button
				pos_hint: {"center_x":0.5}
				size_hint_x: 0.6
				on_release: root.open_employer_menu(self)
				MDButtonText:
					text: "Employers"